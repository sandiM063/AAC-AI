DATABASE_URL="file:./dev.db"

# Email OTP — https://resend.com/api-keys
# With onboarding@resend.dev (Resend sandbox), you can only send to the email
# address verified on your Resend account. Use a verified domain in production.
RESEND_API_KEY=
OTP_EMAIL_FROM="AAC Communicate <onboarding@resend.dev>"

# SMS OTP — https://console.twilio.com
# TWILIO_PHONE_NUMBER = a number you BUY from Twilio (Phone Numbers → Manage → Buy a number).
# It is NOT your personal cell. Trial accounts must also verify recipient numbers under
# Phone Numbers → Verified Caller IDs.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI — https://aistudio.google.com/app/apikey
# Powers the AI Assistant chat and task-board step suggestions (Google Gemini).
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
