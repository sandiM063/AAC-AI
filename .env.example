# =============================================================================
# AAC Communicate — environment variables
# =============================================================================

# --- Database (required) ---
# Use a hosted PostgreSQL database for production (Neon, Supabase, Railway, etc.)
# Example (Neon): postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- App URL (required for Google OAuth on Netlify/production) ---
# Your public site URL with no trailing slash
AUTH_URL="https://your-app.netlify.app"
NEXT_PUBLIC_APP_URL="https://your-app.netlify.app"

# --- Google Sign-In ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.netlify.app/api/auth/google/callback
# (add http://localhost:3000/api/auth/google/callback for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email OTP — https://resend.com/api-keys ---
RESEND_API_KEY=
OTP_EMAIL_FROM="AAC Communicate <onboarding@resend.dev>"

# --- SMS OTP — https://console.twilio.com ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AI — https://aistudio.google.com/app/apikey ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
